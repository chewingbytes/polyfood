---
interface Props {
  title?: string;
  storeName?: string;
}
const { title = "Vendor Dashboard", storeName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Food at Poly Vendor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Space Grotesk', sans-serif;
        background: #1a1a1a;
        color: #fff;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-size: 18px;
      }
      main { flex: 1; }
      button { font-family: 'Space Grotesk', sans-serif; }
    </style>
  </head>
  <body>
    <header style="border-bottom: 6px solid #FFD93D; background: #000; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
      <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <div style="background: #FFD93D; padding: 0.5rem 1rem; border: 3px solid #FFD93D;">
          <span style="font-weight: 900; font-size: 1rem; color: #000; text-transform: uppercase; letter-spacing: 0.05em;">🍱 Food at Poly</span>
        </div>
        {storeName && (
          <span style="font-weight: 900; color: #fff; font-size: 1.25rem;">— {storeName}</span>
        )}
      </div>
      <a
        href="/vendor/logout"
        style="border: 3px solid #FF6B6B; padding: 0.6rem 1.25rem; font-weight: 900; font-size: 1rem; text-decoration: none; color: #FF6B6B; letter-spacing: 0.03em; white-space: nowrap;"
      >
        🚪 Log Out
      </a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
