---
import VendorLayout from "../../layouts/VendorLayout.astro";
import LoginForm from "../../components/vendor/LoginForm.svelte";

// Already logged in → skip to dashboard
const token = Astro.cookies.get("sb-vendor-token")?.value;
if (token) {
  return Astro.redirect("/vendor/dashboard");
}
---

<VendorLayout title="Vendor Login">
  <div
    style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; padding: 2rem;"
  >
    <div style="width: 100%; max-width: 480px;">
      <div style="margin-bottom: 2.5rem; text-align: center;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🍜</div>
        <h1 style="font-size: 2.5rem; font-weight: 900; color: #fff; margin-bottom: 0.5rem; line-height: 1.1;">
          Welcome!
        </h1>
        <p style="color: #aaa; font-weight: 700; font-size: 1.125rem; line-height: 1.5;">
          Enter your email address.<br />We'll send you a login link.
        </p>
      </div>
      <LoginForm client:load />
    </div>
  </div>
</VendorLayout>
