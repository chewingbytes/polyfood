---
import VendorLayout from "../../../layouts/VendorLayout.astro";
---

<VendorLayout title="Signing In">
  <div
    style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;"
  >
    <div
      id="status"
      style="border:4px solid #333;background:#1a1a1a;padding:3rem 2rem;box-shadow:8px 8px 0 #FFD93D;text-align:center;max-width:24rem;width:100%;"
    >
      <div style="font-size:3rem;margin-bottom:1rem;">⏳</div>
      <h1
        style="font-size:1.5rem;font-weight:900;text-transform:uppercase;color:#fff;"
      >
        Signing you in…
      </h1>
    </div>
  </div>
</VendorLayout>

<script>
  import { supabaseBrowser } from "../../../utils/supabase-browser";

  const el = document.getElementById("status")!;

  const ERROR_HTML = `
    <div style="font-size:3rem;margin-bottom:1rem;">❌</div>
    <h1 style="font-size:1.5rem;font-weight:900;text-transform:uppercase;color:#fff;margin-bottom:0.75rem;">Link Expired</h1>
    <p style="font-weight:700;color:#aaa;margin-bottom:1.5rem;">This login link has expired or already been used. Please request a new one.</p>
    <a href="/vendor/login" style="display:inline-block;border:4px solid #FFD93D;background:#FFD93D;color:#000;padding:0.75rem 2rem;font-weight:900;font-size:0.875rem;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;box-shadow:4px 4px 0 #fff;">
      Try Again →
    </a>
  `;

  (async () => {
    const hash = window.location.hash;
    if (hash) {
      const params = new URLSearchParams(hash.slice(1));
      const accessToken = params.get("access_token");
      const refreshToken = params.get("refresh_token");

      if (accessToken && refreshToken) {
        const { error: sessionError } = await supabaseBrowser.auth.setSession({
          access_token: accessToken,
          refresh_token: refreshToken,
        });

        if (!sessionError) {
          // Exchange session for an httpOnly vendor cookie
          const res = await fetch("/api/vendor/auth", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ accessToken }),
          });

          if (res.ok) {
            window.location.href = "/vendor/dashboard";
            return;
          }

          // Email not in Sanity as a vendor
          const body = await res.json().catch(() => ({}));
          el.innerHTML = `
            <div style="font-size:3rem;margin-bottom:1rem;">🚫</div>
            <h1 style="font-size:1.5rem;font-weight:900;text-transform:uppercase;color:#fff;margin-bottom:0.75rem;">Not Authorised</h1>
            <p style="font-weight:700;color:#aaa;margin-bottom:1.5rem;">${body.error ?? "Your email is not registered as a vendor."}</p>
            <a href="/vendor/login" style="display:inline-block;border:4px solid #FFD93D;background:#FFD93D;color:#000;padding:0.75rem 2rem;font-weight:900;font-size:0.875rem;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;box-shadow:4px 4px 0 #fff;">
              Back to Login →
            </a>
          `;
          return;
        }
      }
    }

    el.innerHTML = ERROR_HTML;
  })();
</script>
