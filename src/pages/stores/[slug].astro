---
import { getStore } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AddToCartForm from "../../components/AddToCartForm.svelte";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/polytechnics");

const store = (await getStore(slug)).data;

if (!store) return Astro.redirect("/404");

const spicyLabels = ["Not Spicy", "Mild", "Medium", "Hot", "Extra Hot"];
---

<BaseLayout title={`${store.name} — Food at Poly`}>
  <div class="mx-auto container px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex flex-wrap items-center gap-2" style="font-family: 'Patrick Hand', cursive; font-size: 0.9rem; color: #2d2d2d; opacity: 0.6;">
      <a href="/polytechnics" style="text-decoration: underline; text-decoration-style: wavy;">Polytechnics</a>
      {store.canteen?.polytechnic && (
        <>
          <span>›</span>
          <a href={`/polytechnics/${store.canteen.polytechnic.slug}`} style="text-decoration: underline; text-decoration-style: wavy;">
            {store.canteen.polytechnic.shortName}
          </a>
        </>
      )}
      {store.canteen && (
        <>
          <span>›</span>
          <a href={`/canteens/${store.canteen.slug}`} style="text-decoration: underline; text-decoration-style: wavy;">
            {store.canteen.name}
          </a>
        </>
      )}
      <span>›</span>
      <span style="opacity: 1; color: #2d2d2d;">{store.name}</span>
    </nav>

    <!-- Store header -->
    <div class="mb-12">
      <h1 style="font-family: 'Kalam', cursive; font-size: clamp(2rem, 5vw, 3rem); color: #2d2d2d; margin-bottom: 0.5rem;">
        {store.name}
      </h1>
      <p style="font-family: 'Patrick Hand', cursive; font-size: 1.05rem; color: #2d2d2d; opacity: 0.6;">
        Menu
      </p>
    </div>

    {store.products && store.products.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {store.products.map((product, i) => (
          <div
            style={`background: white; border: 2px solid #2d2d2d; border-radius: ${i % 2 === 0 ? '255px 15px 225px 15px / 15px 225px 15px 255px' : '15px 225px 15px 255px / 225px 15px 255px 15px'}; box-shadow: 5px 5px 0 #2d2d2d; overflow: hidden;`}
          >
            {product.image?.asset?.url && (
              <img
                src={product.image.asset.url}
                alt={product.name}
                style="width: 100%; height: 12rem; object-fit: cover; border-bottom: 2px solid #2d2d2d;"
              />
            )}
            {!product.image?.asset?.url && (
              <div style="width: 100%; height: 12rem; display: flex; align-items: center; justify-content: center; font-size: 4rem; border-bottom: 2px solid #2d2d2d; background: linear-gradient(135deg, #fff9c4, #fde8d8);">
                🍽️
              </div>
            )}
            <div style="padding: 1.5rem;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.75rem;">
                <h3 style="font-family: 'Kalam', cursive; font-size: 1.3rem; color: #2d2d2d; line-height: 1.2;">{product.name}</h3>
                <span style="flex-shrink: 0; font-family: 'Kalam', cursive; font-size: 1.1rem; padding: 3px 10px; background: #fff9c4; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 2px 2px 0 #2d2d2d; white-space: nowrap;">
                  ${product.price.toFixed(2)}
                </span>
              </div>

              {product.description && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.95rem; color: #2d2d2d; opacity: 0.65; margin-bottom: 0.85rem;">{product.description}</p>
              )}

              <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.5rem;">
                {product.isHalal && (
                  <span style="font-family: 'Kalam', cursive; font-size: 0.75rem; padding: 2px 8px; background: #d1fae5; border: 1px solid #2d2d2d; border-radius: 4px;">✓ Halal</span>
                )}
                {product.isVegetarian && (
                  <span style="font-family: 'Kalam', cursive; font-size: 0.75rem; padding: 2px 8px; background: #d1fae5; border: 1px solid #2d2d2d; border-radius: 4px;">🌱 Veg</span>
                )}
                {product.spicyLevel != null && product.spicyLevel > 0 && (
                  <span style="font-family: 'Kalam', cursive; font-size: 0.75rem; padding: 2px 8px; background: #fde8d8; border: 1px solid #2d2d2d; border-radius: 4px;">🌶️ {spicyLabels[product.spicyLevel]}</span>
                )}
                {product.category && (
                  <span style="font-family: 'Kalam', cursive; font-size: 0.75rem; padding: 2px 8px; background: #ede9fe; border: 1px solid #2d2d2d; border-radius: 4px;">{product.category}</span>
                )}
              </div>

              {product.preparationTime && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.8rem; color: #2d2d2d; opacity: 0.5; margin-bottom: 0.5rem;">⏱️ ~{product.preparationTime} mins</p>
              )}

              <div style="margin-top: 1.25rem; padding-top: 1rem; border-top: 1px dashed #e5e0d8;">
                <AddToCartForm
                  client:load
                  productId={product._id}
                  productName={product.name}
                  priceInCents={Math.round((product.price ?? 0) * 100)}
                  storeId={store._id}
                  storeName={store.name}
                  isAvailable={true}
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div style="border: 2px solid #2d2d2d; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; background: white; padding: 4rem; text-align: center; box-shadow: 4px 4px 0 #2d2d2d;">
        <p style="font-family: 'Kalam', cursive; font-size: 1.5rem; color: #2d2d2d;">No menu items yet.</p>
        <p style="font-family: 'Patrick Hand', cursive; color: #2d2d2d; opacity: 0.6; margin-top: 0.5rem;">Add them in the Sanity Studio.</p>
      </div>
    )}
  </div>
</BaseLayout>
