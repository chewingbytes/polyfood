---
import { getStore } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AddToCartForm from "../../components/AddToCartForm.svelte";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/polytechnics");

const store = (await getStore(slug)).data;

if (!store) return Astro.redirect("/404");

const spicyLabels = ["Not Spicy", "Mild", "Medium", "Hot", "Extra Hot"];
---

<BaseLayout title={`${store.name} — Food at Poly`}>
  <div class="mx-auto container px-4 py-16">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex flex-wrap items-center gap-2 text-sm font-bold uppercase tracking-wide">
      <a href="/polytechnics" class="hover:underline">Polytechnics</a>
      {store.canteen?.polytechnic && (
        <>
          <span>›</span>
          <a href={`/polytechnics/${store.canteen.polytechnic.slug}`} class="hover:underline">
            {store.canteen.polytechnic.shortName}
          </a>
        </>
      )}
      {store.canteen && (
        <>
          <span>›</span>
          <a href={`/canteens/${store.canteen.slug}`} class="hover:underline">
            {store.canteen.name}
          </a>
        </>
      )}
      <span>›</span>
      <span class="text-black/50">{store.name}</span>
    </nav>

    <!-- Menu -->
    <h2 class="mb-8 text-4xl font-black uppercase md:text-5xl">Menu</h2>

    {store.products && store.products.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {store.products.map((product) => (
          <div class="border-4 border-black bg-white shadow-[8px_8px_0px_0px_#000]">
            {product.image?.asset?.url && (
              <img
                src={product.image.asset.url}
                alt={product.name}
                class="h-48 w-full border-b-4 border-black object-cover"
              />
            )}
            <div class="p-6">
              <div class="mb-3 flex items-start justify-between gap-2">
                <h3 class="text-2xl font-black uppercase leading-tight">{product.name}</h3>
                <span class="shrink-0 border-4 border-black bg-yellow-300 px-3 py-1 text-xl font-black shadow-[3px_3px_0px_0px_#000]">
                  ${product.price.toFixed(2)}
                </span>
              </div>

              {product.description && (
                <p class="mb-4 font-bold text-black/60">{product.description}</p>
              )}

              <div class="flex flex-wrap gap-2">
                {product.isHalal && (
                  <span class="border-4 border-black bg-green-300 px-2 py-1 text-xs font-black uppercase shadow-[2px_2px_0px_0px_#000]">
                    ✓ Halal
                  </span>
                )}
                {product.isVegetarian && (
                  <span class="border-4 border-black bg-green-100 px-2 py-1 text-xs font-black uppercase shadow-[2px_2px_0px_0px_#000]">
                    🌱 Veg
                  </span>
                )}
                {product.spicyLevel != null && product.spicyLevel > 0 && (
                  <span class="border-4 border-black bg-red-200 px-2 py-1 text-xs font-black uppercase shadow-[2px_2px_0px_0px_#000]">
                    🌶️ {spicyLabels[product.spicyLevel]}
                  </span>
                )}
                {product.category && (
                  <span class="border-4 border-black bg-purple-200 px-2 py-1 text-xs font-black uppercase shadow-[2px_2px_0px_0px_#000]">
                    {product.category}
                  </span>
                )}
              </div>

              {product.preparationTime && (
                <p class="mt-3 text-sm font-bold text-black/50">⏱️ ~{product.preparationTime} mins</p>
              )}

              <div class="mt-5 border-t-2 border-black pt-4">
                <AddToCartForm
                  client:load
                  productId={product._id}
                  productName={product.name}
                  priceInCents={Math.round((product.price ?? 0) * 100)}
                  storeId={store._id}
                  storeName={store.name}
                  isAvailable={true}
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="border-4 border-black bg-white p-16 text-center shadow-[8px_8px_0px_0px_#000]">
        <p class="text-2xl font-black uppercase">No menu items yet.</p>
        <p class="mt-2 font-bold text-black/60">Add them in the Sanity Studio.</p>
      </div>
    )}
  </div>
</BaseLayout>
