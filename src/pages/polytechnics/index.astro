---
import { getAllPolytechnics } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";

const polytechnics = (await getAllPolytechnics()).data;
---

<BaseLayout title="Polytechnics — Food at Poly">
  <div class="mx-auto max-w-7xl px-4 py-14">
    <!-- Page header -->
    <div class="mb-12 text-center">
      <div class="inline-block mb-4 px-4 py-1.5 -rotate-1"
           style="background: #fff9c4; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d; font-family: 'Kalam', cursive; font-size: 0.9rem;">
        🏫 All 5 Polytechnics
      </div>
      <h1 style="font-family: 'Kalam', cursive; font-size: clamp(2.2rem, 6vw, 3.5rem); color: #2d2d2d; margin-bottom: 0.75rem;">
        Choose Your Polytechnic
      </h1>
      <p style="font-family: 'Patrick Hand', cursive; font-size: 1.1rem; color: #2d2d2d; opacity: 0.65; max-width: 28rem; margin: 0 auto;">
        Pick your campus and explore canteens and food stores.
      </p>
    </div>

    {polytechnics && polytechnics.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {polytechnics.map((poly, i) => (
          <a
            href={`/polytechnics/${poly.slug}`}
            style={`display: block; background: white; border: 2px solid #2d2d2d; border-radius: ${i % 2 === 0 ? '255px 15px 225px 15px / 15px 225px 15px 255px' : '15px 225px 15px 255px / 225px 15px 255px 15px'}; box-shadow: 5px 5px 0 #2d2d2d; overflow: hidden; transition: all 150ms ease; transform: rotate(${[-0.8, 0.5, -0.5, 0.8, -0.3][i % 5]}deg); text-decoration: none; color: inherit;`}
            onmouseover="this.style.transform='translateY(-4px) rotate(0deg)'; this.style.boxShadow='7px 7px 0 #2d2d2d';"
            onmouseout={`this.style.transform='rotate(${[-0.8, 0.5, -0.5, 0.8, -0.3][i % 5]}deg)'; this.style.boxShadow='5px 5px 0 #2d2d2d';`}
          >
            {poly.image?.asset?.url && (
              <img
                src={poly.image.asset.url}
                alt={poly.name}
                style="width: 100%; height: 12rem; object-fit: cover; border-bottom: 2px solid #2d2d2d;"
              />
            )}
            {!poly.image?.asset?.url && (
              <div style="width: 100%; height: 12rem; display: flex; align-items: center; justify-content: center; font-size: 4rem; border-bottom: 2px solid #2d2d2d; background: linear-gradient(135deg, #fff9c4, #dbeafe);">
                🏛️
              </div>
            )}
            <div style="padding: 1.5rem;">
              <div class="inline-block mb-3 px-3 py-1"
                   style={`font-family: 'Kalam', cursive; font-size: 1.2rem; font-weight: 700; background: ${['#dbeafe','#fff9c4','#d1fae5','#fde8d8','#ede9fe'][i % 5]}; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d;`}>
                {poly.shortName}
              </div>
              <h2 style="font-family: 'Kalam', cursive; font-size: 1.35rem; color: #2d2d2d; margin-bottom: 0.5rem; line-height: 1.2;">
                {poly.name}
              </h2>
              {poly.description && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.95rem; color: #2d2d2d; opacity: 0.65; margin-bottom: 0.5rem;">
                  {poly.description}
                </p>
              )}
              {poly.address && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.85rem; color: #2d2d2d; opacity: 0.5;">📍 {poly.address}</p>
              )}
            </div>
            <div style="padding: 0.85rem 1.5rem; border-top: 2px solid #2d2d2d; background: #ff4d4d;">
              <span style="font-family: 'Kalam', cursive; font-size: 0.9rem; color: white; font-weight: 700;">
                View Canteens →
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="border: 2px solid #2d2d2d; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; background: white; padding: 4rem; text-align: center; box-shadow: 4px 4px 0 #2d2d2d;">
        <p style="font-family: 'Kalam', cursive; font-size: 1.5rem; color: #2d2d2d;">No polytechnics yet.</p>
        <p style="font-family: 'Patrick Hand', cursive; color: #2d2d2d; opacity: 0.6; margin-top: 0.5rem;">Add them in the Sanity Studio.</p>
      </div>
    )}
  </div>
</BaseLayout>
