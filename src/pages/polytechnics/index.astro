---
import { getAllPolytechnics } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";

const polytechnics = (await getAllPolytechnics()).data;
---

<BaseLayout title="Polytechnics — Food at Poly">
  <div class="mx-auto container px-4 py-16">
    <h1 class="mb-2 text-3xl font-black uppercase leading-none md:text-5xl">Polytechnics</h1>
    <p class="mb-12 text-lg md:text-xl font-bold text-black/60">Choose your polytechnic to explore canteens and food stores.</p>

    {polytechnics && polytechnics.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {polytechnics.map((poly) => (
          <a
            href={`/polytechnics/${poly.slug}`}
            class="group block border-4 border-black bg-white shadow-[8px_8px_0px_0px_#000] transition-all duration-200 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_#000]"
          >
            {poly.image?.asset?.url && (
              <img
                src={poly.image.asset.url}
                alt={poly.name}
                class="h-48 w-full border-b-4 border-black object-cover"
              />
            )}
            <div class="p-6">
              <div class="mb-3 inline-block border-4 border-black bg-yellow-300 px-3 py-1 text-2xl font-black shadow-[3px_3px_0px_0px_#000]">
                {poly.shortName}
              </div>
              <h2 class="mb-2 text-2xl font-black uppercase leading-tight">{poly.name}</h2>
              {poly.description && (
                <p class="mb-3 font-bold text-black/60">{poly.description}</p>
              )}
              {poly.address && (
                <p class="text-sm font-bold text-black/50">📍 {poly.address}</p>
              )}
            </div>
            <div class="border-t-4 border-black bg-red-400 px-6 py-3">
              <span class="text-sm font-black uppercase tracking-widest">View Canteens →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="border-4 border-black bg-white p-16 text-center shadow-[8px_8px_0px_0px_#000]">
        <p class="text-2xl font-black uppercase">No polytechnics yet.</p>
        <p class="mt-2 font-bold text-black/60">Add them in the Sanity Studio.</p>
      </div>
    )}
  </div>
</BaseLayout>
