---
import { getPolytechnic } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/polytechnics");
}

const polytechnic = (await getPolytechnic(slug)).data;

if (!polytechnic) {
  return Astro.redirect("/404");
}
---

<BaseLayout title={`${polytechnic.name} - Food at Poly`}>
  <div class="container mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex flex-wrap items-center gap-2" style="font-family: 'Patrick Hand', cursive; font-size: 0.9rem; color: #2d2d2d; opacity: 0.6;">
      <a href="/polytechnics" class="hover:opacity-100 transition-opacity" style="text-decoration: underline; text-decoration-style: wavy;">Polytechnics</a>
      <span>›</span>
      <span style="opacity: 1; color: #2d2d2d;">{polytechnic.shortName}</span>
    </nav>

    <!-- Page header -->
    <div class="mb-12">
      <div class="inline-block mb-4 px-4 py-1.5 rotate-1"
           style="background: #dbeafe; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d; font-family: 'Kalam', cursive; font-size: 0.9rem;">
        {polytechnic.shortName}
      </div>
      <h1 style="font-family: 'Kalam', cursive; font-size: clamp(2rem, 5vw, 3.2rem); color: #2d2d2d; line-height: 1.1;">
        {polytechnic.name} Canteens
      </h1>
    </div>

    {polytechnic.canteens && polytechnic.canteens.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {polytechnic.canteens.map((canteen, i) => (
          <a
            href={`/canteens/${canteen.slug}`}
            style={`display: block; background: white; border: 2px solid #2d2d2d; border-radius: ${i % 2 === 0 ? '255px 15px 225px 15px / 15px 225px 15px 255px' : '15px 225px 15px 255px / 225px 15px 255px 15px'}; box-shadow: 5px 5px 0 #2d2d2d; overflow: hidden; transition: all 150ms ease; transform: rotate(${[-0.5, 0.7, -0.3][i % 3]}deg); text-decoration: none; color: inherit;`}
            onmouseover="this.style.transform='translateY(-4px) rotate(0deg)'; this.style.boxShadow='7px 7px 0 #2d2d2d';"
            onmouseout={`this.style.transform='rotate(${[-0.5, 0.7, -0.3][i % 3]}deg)'; this.style.boxShadow='5px 5px 0 #2d2d2d';`}
          >
            {canteen.image?.asset?.url ? (
              <img
                src={canteen.image.asset.url}
                alt={canteen.name}
                style="width: 100%; height: 11rem; object-fit: cover; border-bottom: 2px solid #2d2d2d;"
              />
            ) : (
              <div style="width: 100%; height: 11rem; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; border-bottom: 2px solid #2d2d2d; background: linear-gradient(135deg, #fff9c4, #d1fae5);">
                🍽️
              </div>
            )}
            <div style="padding: 1.5rem;">
              <h3 style="font-family: 'Kalam', cursive; font-size: 1.4rem; color: #2d2d2d; margin-bottom: 0.5rem;">
                {canteen.name}
              </h3>
              {canteen.location && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.9rem; color: #2d2d2d; opacity: 0.6; margin-bottom: 0.35rem;">📍 {canteen.location}</p>
              )}
              {canteen.openingHours && (
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.85rem; color: #2d2d2d; opacity: 0.5;">🕒 {canteen.openingHours}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="border: 2px solid #e5e0d8; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; background: white; padding: 3rem; text-align: center;">
        <p style="font-family: 'Kalam', cursive; font-size: 1.3rem; color: #2d2d2d; opacity: 0.6;">No canteens available yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
