---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllFoodProducts } from "../data/sanity";

// Fetch all food products
const allProducts = (await getAllFoodProducts()).data || [];

// Group products by polytechnic
const productsByPoly: Record<string, any[]> = {};
allProducts.forEach((product) => {
  const polySlug = product.store?.canteen?.polytechnic?.slug;
  if (polySlug) {
    if (!productsByPoly[polySlug]) {
      productsByPoly[polySlug] = [];
    }
    productsByPoly[polySlug].push(product);
  }
});

// Top Favorites Overall - one random product from each poly
const topFavorites = Object.keys(productsByPoly).map((polySlug) => {
  const products = productsByPoly[polySlug];
  const randomProduct = products[Math.floor(Math.random() * products.length)];
  return randomProduct;
}).filter(Boolean).slice(0, 6);

// Polytechnic data for sections
const polytechnics = [
  { slug: "sp", shortName: "SP", name: "Singapore Polytechnic" },
  { slug: "np", shortName: "NP", name: "Ngee Ann Polytechnic" },
  { slug: "tp", shortName: "TP", name: "Temasek Polytechnic" },
  { slug: "nyp", shortName: "NYP", name: "Nanyang Polytechnic" },
  { slug: "rp", shortName: "RP", name: "Republic Polytechnic" },
];
---

<BaseLayout title="Food at Poly — Singapore Polytechnic Food Ordering">
  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section style="padding: 5rem 1rem 4rem; position: relative; overflow: hidden;">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Floating tag -->
      <div class="inline-block mb-6 px-4 py-1.5 -rotate-2"
           style="background: #fff9c4; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d; font-family: 'Kalam', cursive; font-size: 0.9rem; color: #2d2d2d;">
        🍜 Singapore Polytechnic Food Orders
      </div>

      <h1 style="font-family: 'Kalam', cursive; font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 700; line-height: 1.1; color: #2d2d2d; margin-bottom: 1.5rem;">
        Hungry at&nbsp;Poly?<br/>
        <span style="color: #ff4d4d; position: relative; display: inline-block; transform: rotate(-1deg);">
          We've Got You!
        </span>
      </h1>

      <p style="font-family: 'Patrick Hand', cursive; font-size: 1.2rem; color: #2d2d2d; opacity: 0.75; max-width: 32rem; margin: 0 auto 2.5rem;">
        Browse canteen menus from all 5 Singapore polytechnics and find your next meal in minutes.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/polytechnics" class="btn btn-primary" style="font-size: 1.05rem; padding: 0.65rem 2rem;">
          Browse Polytechnics →
        </a>
        <a href="/polytechnics/sp" class="btn" style="font-size: 1.05rem; padding: 0.65rem 2rem;">
          Start with SP
        </a>
      </div>

      <!-- Poly pills -->
      <div class="flex flex-wrap justify-center gap-2 mt-10">
        {polytechnics.map((p, i) => (
          <a href={`/polytechnics/${p.slug}`}
             style={`font-family: 'Kalam', cursive; font-size: 0.85rem; padding: 0.3rem 0.9rem; background: white; border: 2px solid #2d2d2d; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; box-shadow: 3px 3px 0 #2d2d2d; transform: rotate(${[-1, 1, -0.5, 0.8, -1.2][i]}deg); display: inline-block; transition: all 120ms; color: #2d2d2d; text-decoration: none;`}
             onmouseover="this.style.transform='translateY(-2px) rotate(0deg)'; this.style.background='#ff4d4d'; this.style.color='white';"
             onmouseout={`this.style.transform='rotate(${[-1, 1, -0.5, 0.8, -1.2][i]}deg)'; this.style.background='white'; this.style.color='#2d2d2d';`}>
            {p.shortName}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ TOP FAVORITES ═══════════════════════ -->
  <section style="padding: 4rem 1rem; border-top: 2px solid #e5e0d8;">
    <div class="mx-auto max-w-7xl">
      <!-- Section header -->
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <div class="inline-block mb-2 px-3 py-1 -rotate-1"
               style="background: #ff4d4d; color: white; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d; font-family: 'Kalam', cursive; font-size: 0.8rem;">
            ⭐ Most Popular
          </div>
          <h2 style="font-family: 'Kalam', cursive; font-size: clamp(2rem, 5vw, 3rem); color: #2d2d2d; line-height: 1.1;">
            Top Favorites
          </h2>
        </div>
        <a href="/polytechnics" class="btn" style="font-size: 0.9rem; padding: 0.4rem 1rem;">
          View All →
        </a>
      </div>

      {topFavorites.length > 0 ? (
        <div class="grid grid-cols-2 gap-5 md:grid-cols-3 lg:grid-cols-6">
          {topFavorites.map((product, i) => (
            <a href={`/stores/${product.store?.slug}`}
               class="group"
               style={`display: block; background: white; border: 2px solid #2d2d2d; border-radius: ${i % 2 === 0 ? '255px 15px 225px 15px / 15px 225px 15px 255px' : '15px 225px 15px 255px / 225px 15px 255px 15px'}; box-shadow: 4px 4px 0 #2d2d2d; overflow: hidden; transition: all 150ms ease; transform: rotate(${[-1, 0.5, -0.8, 1, -0.5, 0.8][i]}deg); text-decoration: none; color: inherit;`}
               onmouseover="this.style.transform='translateY(-4px) rotate(0deg)'; this.style.boxShadow='6px 6px 0 #2d2d2d';"
               onmouseout={`this.style.transform='rotate(${[-1, 0.5, -0.8, 1, -0.5, 0.8][i]}deg)'; this.style.boxShadow='4px 4px 0 #2d2d2d';`}>
              {product.image?.asset?.url ? (
                <img
                  src={product.image.asset.url}
                  alt={product.name}
                  style="width: 100%; aspect-ratio: 1; object-fit: cover; border-bottom: 2px solid #2d2d2d;"
                />
              ) : (
                <div style="width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 3rem; border-bottom: 2px solid #2d2d2d; background: linear-gradient(135deg, #fff9c4, #fde8d8);">
                  🍽️
                </div>
              )}
              <div style="padding: 0.75rem;">
                <p style="font-family: 'Kalam', cursive; font-size: 0.85rem; font-weight: 700; color: #2d2d2d; margin-bottom: 0.25rem; line-height: 1.2;">{product.name}</p>
                <p style="font-family: 'Patrick Hand', cursive; font-size: 0.75rem; color: #2d2d2d; opacity: 0.6; margin-bottom: 0.4rem;">{product.store?.name}</p>
                <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                  <span style="font-family: 'Kalam', cursive; font-size: 0.7rem; padding: 1px 6px; background: #ff4d4d; color: white; border: 1px solid #2d2d2d; border-radius: 4px;">
                    ${product.price.toFixed(2)}
                  </span>
                  <span style="font-family: 'Kalam', cursive; font-size: 0.7rem; padding: 1px 6px; background: #dbeafe; border: 1px solid #2d2d2d; border-radius: 4px;">
                    {product.store?.canteen?.polytechnic?.shortName}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div style="border: 2px solid #2d2d2d; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; background: white; padding: 4rem; text-align: center; box-shadow: 4px 4px 0 #2d2d2d;">
          <p style="font-family: 'Kalam', cursive; font-size: 1.5rem; color: #2d2d2d;">No products yet.</p>
          <p style="font-family: 'Patrick Hand', cursive; color: #2d2d2d; opacity: 0.6; margin-top: 0.5rem;">Add food products in the Sanity Studio.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════ BY POLYTECHNIC ═══════════════════════ -->
  {polytechnics.map((poly, polyIdx) => {
    const products = productsByPoly[poly.slug]?.slice(0, 4) || [];
    if (products.length === 0) return null;
    const bgColors = ['#fdfbf7', '#fff9c4', '#fdfbf7', '#fde8d8', '#fdfbf7'];
    return (
      <section style={`padding: 4rem 1rem; border-top: 2px solid #e5e0d8; background-color: ${bgColors[polyIdx]};`}>
        <div class="mx-auto max-w-7xl">
          <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
            <div>
              <div class="inline-block mb-2 px-3 py-1"
                   style={`background: ${['#dbeafe', '#fff9c4', '#d1fae5', '#fde8d8', '#ede9fe'][polyIdx]}; border: 2px solid #2d2d2d; border-radius: 4px 8px 4px 8px / 8px 4px 8px 4px; box-shadow: 3px 3px 0 #2d2d2d; font-family: 'Kalam', cursive; font-size: 0.85rem; color: #2d2d2d; transform: rotate(${[1, -1, 0.5, -0.5, 1][polyIdx]}deg); display: inline-block;`}>
                {poly.shortName}
              </div>
              <h2 style="font-family: 'Kalam', cursive; font-size: clamp(1.5rem, 4vw, 2.2rem); color: #2d2d2d;">
                {poly.name}
              </h2>
            </div>
            <a href={`/polytechnics/${poly.slug}`} class="btn btn-primary" style="font-size: 0.9rem; padding: 0.4rem 1rem;">
              View All →
            </a>
          </div>

          <div class="grid grid-cols-2 gap-5 md:grid-cols-4">
            {products.map((product, i) => (
              <a href={`/stores/${product.store?.slug}`}
                 style={`display: block; background: white; border: 2px solid #2d2d2d; border-radius: ${i % 2 === 0 ? '255px 15px 225px 15px / 15px 225px 15px 255px' : '15px 225px 15px 255px / 225px 15px 255px 15px'}; box-shadow: 4px 4px 0 #2d2d2d; overflow: hidden; transition: all 150ms ease; text-decoration: none; color: inherit;`}
                 onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='6px 6px 0 #2d2d2d';"
                 onmouseout="this.style.transform=''; this.style.boxShadow='4px 4px 0 #2d2d2d';">
                {product.image?.asset?.url ? (
                  <img src={product.image.asset.url} alt={product.name}
                       style="width: 100%; aspect-ratio: 1; object-fit: cover; border-bottom: 2px solid #2d2d2d;" />
                ) : (
                  <div style="width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; border-bottom: 2px solid #2d2d2d; background: linear-gradient(135deg, #fff9c4, #dbeafe);">🍽️</div>
                )}
                <div style="padding: 0.85rem;">
                  <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.4rem;">
                    <p style="font-family: 'Kalam', cursive; font-size: 0.95rem; font-weight: 700; color: #2d2d2d; line-height: 1.2;">{product.name}</p>
                    <span style="flex-shrink: 0; font-family: 'Kalam', cursive; font-size: 0.85rem; padding: 2px 8px; background: #fff9c4; border: 1px solid #2d2d2d; border-radius: 4px;">${product.price.toFixed(2)}</span>
                  </div>
                  <p style="font-family: 'Patrick Hand', cursive; font-size: 0.8rem; color: #2d2d2d; opacity: 0.6; margin-bottom: 0.5rem;">{product.store?.name}</p>
                  {product.category && (
                    <span style="font-family: 'Kalam', cursive; font-size: 0.7rem; padding: 1px 7px; background: #fde8d8; border: 1px solid #2d2d2d; border-radius: 4px;">{product.category}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- ═══════════════════════ HOW IT WORKS ═══════════════════════ -->
  <section style="padding: 5rem 1rem; border-top: 2px solid #e5e0d8;">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center mb-12" style="font-family: 'Kalam', cursive; font-size: clamp(2rem, 5vw, 3rem); color: #2d2d2d;">
        How It Works ✏️
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {[
          { num: "1", emoji: "🏫", title: "Pick Your Poly", desc: "Choose from any of the 5 Singapore polytechnics.", rot: "-rotate-1" },
          { num: "2", emoji: "🍜", title: "Browse Canteens", desc: "Explore all canteens in your polytechnic campus.", rot: "rotate-1" },
          { num: "3", emoji: "🛒", title: "Order Your Food", desc: "Check out stores and their full menus with prices.", rot: "-rotate-1" },
        ].map((step) => (
          <div class={step.rot}
               style="position: relative; background: white; border: 2px solid #2d2d2d; border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; box-shadow: 5px 5px 0 #2d2d2d; padding: 2rem; text-align: center;">
            <div style="font-size: 3rem; margin-bottom: 0.75rem;">{step.emoji}</div>
            <div style="font-family: 'Kalam', cursive; font-size: 2rem; font-weight: 700; color: #ff4d4d; margin-bottom: 0.25rem;">{step.num}</div>
            <h3 style="font-family: 'Kalam', cursive; font-size: 1.3rem; color: #2d2d2d; margin-bottom: 0.5rem;">{step.title}</h3>
            <p style="font-family: 'Patrick Hand', cursive; color: #2d2d2d; opacity: 0.7;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
