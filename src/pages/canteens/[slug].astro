---
import { getCanteen } from "../../data/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/polytechnics");

const canteen = (await getCanteen(slug)).data;

if (!canteen) return Astro.redirect("/404");
---

<BaseLayout title={`${canteen.name} — Food at Poly`}>
  <div class="container mx-auto px-4 py-16">
    <!-- Breadcrumb -->
    <nav class="mb-10 flex flex-wrap items-center gap-2 text-sm font-bold uppercase tracking-wide">
      <a href="/polytechnics" class="hover:underline">Polytechnics</a>
      {canteen.polytechnic && (
        <>
          <span>›</span>
          <a href={`/polytechnics/${canteen.polytechnic.slug}`} class="hover:underline">
            {canteen.polytechnic.shortName}
          </a>
        </>
      )}
      <span>›</span>
      <span class="text-black/50">{canteen.name}</span>
    </nav>

    <h2 class="mb-8 text-4xl font-black uppercase md:text-5xl">{canteen.name} Food Stores</h2>

    {canteen.stores && canteen.stores.length > 0 ? (
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {canteen.stores.map((store) => (
          <a
            href={`/stores/${store.slug}`}
            class="block border-4 border-black bg-white shadow-[8px_8px_0px_0px_#000] transition-all duration-200 hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_#000]"
          >
            {store.image?.asset?.url && (
              <img
                src={store.image.asset.url}
                alt={store.name}
                class="h-48 w-full border-b-4 border-black object-cover"
              />
            )}
            <div class="p-6">
              <h3 class="mb-2 text-2xl font-black uppercase">{store.name}</h3>
              {store.cuisine && (
                <div class="mb-3 inline-block border-4 border-black bg-red-400 px-3 py-1 text-sm font-black shadow-[3px_3px_0px_0px_#000]">
                  {store.cuisine}
                </div>
              )}
              {store.stallNumber && (
                <p class="text-sm font-bold text-black/50">Stall {store.stallNumber}</p>
              )}
              {store.contactNumber && (
                <p class="text-sm font-bold text-black/50">📞 {store.contactNumber}</p>
              )}
            </div>
            <div class="border-t-4 border-black bg-yellow-300 px-6 py-3">
              <span class="text-sm font-black uppercase tracking-widest">See Menu →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="border-4 border-black bg-white p-16 text-center shadow-[8px_8px_0px_0px_#000]">
        <p class="text-2xl font-black uppercase">No stores yet.</p>
        <p class="mt-2 font-bold text-black/60">Add them in the Sanity Studio.</p>
      </div>
    )}
  </div>
</BaseLayout>
